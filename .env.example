NEXT_PUBLIC_AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Browser MediaRecorder saves recordings locally, so no Agora REST or S3 keys are required.
# Optional: set these to upload completed recordings to Backblaze B2 through the server API.
BACKBLAZE_KEY_ID=your_backblaze_key_id
BACKBLAZE_APPLICATION_KEY=your_backblaze_application_key
BACKBLAZE_BUCKET=your_bucket_name
